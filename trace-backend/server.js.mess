app.post('/trace/api/nodes', auth, async (req, res) => {
  console.log('POST_NODES_HANDLER CALLED');
  const { batch_id, node_code, title, content, sort_order } = req.body;
  const db = await getDb();
  const r = db.run('INSERT INTO trace_nodes (batch_id, node_code, title, content, sort_order) VALUES (?,?,?,?,?)', [batch_id, node_code, title || '', content || '', sort_order || 0]);
  const nodeId = Number(db.exec('SELECT last_insert_rowid() as id')[0].values[0][0]);
  saveDb();
  res.json({ ok: true, id: nodeId });
});

