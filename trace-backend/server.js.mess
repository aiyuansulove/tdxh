// ==================== SN Codes ====================
app.get('/trace/api/sncodes', auth, async (req, res) => {
  const db = await getDb();
  const r = db.exec('SELECT s.*, p.name as product_name, b.batch_no FROM sn_codes s JOIN products p ON s.product_id = p.id JOIN batches b ON s.batch_id = b.id ORDER BY s.id DESC LIMIT 200');
  const items = [];
  if (r.length && r[0].values.length) {
    const cols = r[0].columns;
    for (const v of r[0].values) {
      const o = {};
      cols.forEach((c, i) => o[c] = v[i]);
      items.push(o);
    }
  }
  res.json(items);
});

app.post('/trace/api/sncodes/generate', auth, async (req, res) => {
  const { product_id, batch_id, count } = req.body;
  const num = Math.min(count || 10, 1000);
  const db = await getDb();
  const prefix = 'TDXH';
  const year = String(new Date().getFullYear()).slice(2);
  const prodCode = (String(product_id)).padStart(2, '0');
  const created = [];
  
  for (let i = 0; i < num; i++) {
    const rand = String(Math.floor(Math.random() * 9999)).padStart(4, '0');
    const seq = String(Date.now() % 100000 + i).padStart(5, '0');
    const sn = `${prefix}${year}${prodCode}${seq}${rand}`;
    try {
      db.run('INSERT INTO sn_codes (sn, product_id, batch_id) VALUES (?,?,?)', [sn, product_id, batch_id]);
      created.push(sn);
    } catch (e) { continue; }
  }
  saveDb();
  res.json({ ok: true, count: created.length, sncodes: created });
});

app.put('/trace/api/sncodes/:id/status', auth, async (req, res) => {
  const { status } = req.body;
  const db = await getDb();
  db.run('UPDATE sn_codes SET status=? WHERE id=?', [status, req.params.id]);
  saveDb();
  res.json({ ok: true });
});

// ==================== Statistics ====================
app.get('/trace/api/stats', auth, async (req, res) => {
  const db = await getDb();
  const totalSN = db.exec('SELECT COUNT(*) as c FROM sn_codes')[0].values[0][0];
  const totalQuery = db.exec('SELECT COUNT(*) as c FROM query_logs')[0].values[0][0];
  const todayQuery = db.exec("SELECT COUNT(*) as c FROM query_logs WHERE created_at >= datetime('now','-1 day')")[0].values[0][0];
  const totalProducts = db.exec('SELECT COUNT(*) as c FROM products')[0].values[0][0];
  const totalBatches = db.exec('SELECT COUNT(*) as c FROM batches')[0].values[0][0];
  res.json({ totalSN, totalQuery, todayQuery, totalProducts, totalBatches });
});


// ==================== Node Media ====================
app.post('/trace/api/nodes/:id/media', auth, async (req, res) => {
  const { media } = req.body;
  if (!media || !Array.isArray(media)) return res.json({ ok: true });
  const db = await getDb();
  for (const m of media) {
    db.run('INSERT INTO trace_media (trace_node_id, media_type, url, description, sort_order) VALUES (?,?,?,?,?)',
      [req.params.id, m.media_type || 'image', m.url, m.description || '', m.sort_order || 0]);
  }
  saveDb();
  res.json({ ok: true, count: media.length });
});

// ==================== Start ====================
async function start() {
  await initDb();
  app.listen(PORT, () => {
    console.log(`Trace backend running at http://localhost:${PORT}/trace`);
    console.log(`Admin: http://localhost:${PORT}/trace/admin`);
  });
}

start();
