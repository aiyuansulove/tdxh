// ==================== Trace Nodes CRUD ====================
app.get('/trace/api/nodes/:batchId', auth, async (req, res) => {
  const db = await getDb();
  const r = db.exec('SELECT t.*, n.name as type_name, n.icon as type_icon FROM trace_nodes t JOIN trace_node_types n ON t.node_code = n.code WHERE t.batch_id = ? ORDER BY t.sort_order, t.id', [req.params.batchId]);
  const items = [];
  if (r.length && r[0].values.length) {
    const cols = r[0].columns;
    for (const v of r[0].values) {
      const o = {};
      cols.forEach((c, i) => o[c] = v[i]);
      // Get media
      const mr = db.exec('SELECT * FROM trace_media WHERE trace_node_id = ? ORDER BY sort_order, id', [o.id]);
      o.media = [];
      if (mr.length && mr[0].values.length) {
        const mCols = mr[0].columns;
        for (const mv of mr[0].values) {
          const m = {};
          mCols.forEach((c, i) => m[c] = mv[i]);
          o.media.push(m);
        }
      }
      items.push(o);
    }
  }
  res.json(items);
});

